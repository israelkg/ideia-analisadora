# idea-analyzer · production env (server only, chmod 600). Infra-only — the
# OpenAI/AvisaAPI keys and group allowlist are set in the UI at /admin.
PORT=4500
WEBHOOK_TOKEN=__set_a_long_random_token__
ADMIN_PASSWORD=__set_a_strong_password__
# Keep this safe: it decrypts the stored API keys. Losing it = re-enter keys.
SECRETS_ENCRYPTION_KEY=__set_a_long_random_key__
SETTINGS_PATH=/data/settings.json
# Public origin — seeds the webhook URL so /admin comes pre-filled.
PUBLIC_BASE_URL=https://ideias.berrysystem.com.br
