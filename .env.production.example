# idea-analyzer · production env (server only, chmod 600). Do NOT commit the real one.
PORT=4500
WEBHOOK_TOKEN=__set_a_long_random_token__

AVISA_BASE_URL=https://api.avisaapi.com.br
AVISA_API_KEY=__avisa_api_key__

# Restrict to the colleagues' group JID (recommended). Empty = any group.
GROUP_ALLOWLIST=
ALLOW_DIRECT=false

LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_WEB_SEARCH=true
