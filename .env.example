# --- Server ---
PORT=4500
# Secret path segment for the webhook URL: /webhook/<WEBHOOK_TOKEN>
WEBHOOK_TOKEN=change-me

# --- AvisaAPI (WhatsApp gateway) ---
AVISA_BASE_URL=https://api.avisaapi.com.br
AVISA_API_KEY=your-avisa-api-key

# Restrict which group(s) the bot answers in (comma-separated chat JIDs like
# 120363012345678901@g.us). Leave empty to answer in ANY group.
GROUP_ALLOWLIST=

# Also analyze ideas sent in direct messages (not only groups). default: false
ALLOW_DIRECT=false

# --- LLM provider (configurable; start with OpenAI) ---
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
# Any model that supports the Responses API web_search tool (e.g. gpt-4o, gpt-4.1).
OPENAI_MODEL=gpt-4o
# Ground the analysis with real web search for competitor/market checks.
OPENAI_WEB_SEARCH=true
