# Infra-only env. Provider/AvisaAPI keys are configured in the UI at /admin
# (stored encrypted in the settings file) — NOT here.

PORT=4500
# Secret path segment for the webhook URL: /webhook/<WEBHOOK_TOKEN>
WEBHOOK_TOKEN=change-me

# Password for the /admin Integrações page (HTTP Basic, user: admin).
ADMIN_PASSWORD=change-me

# Encrypts API keys at rest in the settings file. Keep it safe — if lost, the
# stored keys become unreadable and must be re-entered.
SECRETS_ENCRYPTION_KEY=dev-only-insecure-key-change-me

# Where the JSON settings store lives (mount a volume at its dir in prod).
SETTINGS_PATH=./data/settings.json
